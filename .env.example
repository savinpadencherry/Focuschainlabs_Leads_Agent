# Required. You can use GEMINI_API_KEY or GOOGLE_API_KEY.
GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Required — get free 2,500 searches at serper.dev
SERPER_API_KEY=

# Required for contact enrichment when Apollo is unavailable.
# Free tier: $5/month ≈ 500 company website scrapes + 1,250 LinkedIn lookups
# Get key at: apify.com → Settings → Integrations → API token
APIFY_API_KEY=

# Optional — Apollo can be added later when credits/budget are available.
APOLLO_API_KEY=

# Optional — free 25/mo at hunter.io, used for email finding + verification
# When set, dramatically improves email accuracy for non-Apollo contacts
HUNTER_API_KEY=

# Optional — paid, nubela.co/proxycurl
PROXYCURL_API_KEY=

# Optional — paid, tracxn.com
TRACXN_API_KEY=

# Agent behaviour
PILOT_MODE=true
MAX_LEADS_PER_RUN=30
MIN_SCORE_THRESHOLD=60
CONTACT_ENRICH_CAP=30

# CRM — GitHub-backed persistence (required on Streamlit Cloud Community)
# Classic PAT with repo scope: github.com/settings/tokens
GITHUB_TOKEN=
GITHUB_REPO=savinpadencherry/Focuschainlabs_Leads_Agent
GITHUB_BRANCH=main
CRM_DATA_PATH=data/crm/contacts.json
FEEDBACK_DATA_PATH=data/crm/feedback.json
